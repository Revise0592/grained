generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Roll {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  // Film
  filmStock    String?
  filmFormat   String? // 35mm, 120, 4x5, LF
  iso          Int?
  pushPull     String? // "0", "+1", "-2", etc.

  // Camera
  camera String?
  lens   String?

  // Dates
  dateShotStart DateTime?
  dateShotEnd   DateTime?

  // Lab / Development
  lab            String?
  dateDeveloped  DateTime?
  developProcess String? // C-41, E-6, B&W, Cross-process

  // Meta
  coverPhotoId String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  photos   Photo[]
  comments RollComment[]
  tags     Tag[]
}

model Photo {
  id           String @id @default(cuid())
  rollId       String
  roll         Roll   @relation(fields: [rollId], references: [id], onDelete: Cascade)
  filename     String
  originalName String
  path         String
  width        Int?
  height       Int?
  frameNumber  Int?
  order        Int    @default(0)

  rotation     Int      @default(0) // 0, 90, 180, 270

  // Per-frame overrides
  shutterSpeed String?
  aperture     String?
  exposureComp String?
  focalLength  String?
  notes        String?

  createdAt DateTime @default(now())

  comments PhotoComment[]
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  rolls Roll[]
}

model RollComment {
  id        String   @id @default(cuid())
  rollId    String
  roll      Roll     @relation(fields: [rollId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}

model PhotoComment {
  id        String   @id @default(cuid())
  photoId   String
  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}

model SavedCamera {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model SavedFilmStock {
  id        String   @id @default(cuid())
  name      String   @unique
  iso       Int?
  createdAt DateTime @default(now())
}

model AppSettings {
  id                 String   @id @default("singleton")
  metadataDefaults   Json
  importDefaults     Json
  displayPreferences Json
  libraryBehavior    Json
  dataSafety         Json
  updatedAt          DateTime @updatedAt
}

model Settings {
  id                   Int    @id @default(1)
  defaultLab           String?
  defaultDevelopProcess String?
  defaultFilmFormat    String?
  defaultCommonTags    Json?
}

model AuthSession {
  id        String   @id
  createdAt DateTime @default(now())
  expiresAt DateTime
  revokedAt DateTime?
}

model AdminAccount {
  id                String   @id @default("singleton")
  passwordHash      String
  passwordSalt      String
  passwordUpdatedAt DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}
